generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Define the Application Status Enum
enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  REJECTED
}

// 2. Define the User Table
model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  applications Application[] // One-to-Many Relation: A user can have many job applications
}

// 3. Define the Application Table
model Application {
  id         Int         @id @default(autoincrement())
  company    String
  role       String
  status     String      @default("APPLIED")
  notes      String?
  userId     Int
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviews Interview[] 
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Interview {
  id            Int         @id @default(autoincrement())
  applicationId Int
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  date          DateTime
  time          String
  round         String      
  format        String      
  notes         String?     // 🛠️ ADD THIS LINE
  location      String?     
  completed     Boolean     @default(false)
  createdAt     DateTime    @default(now())
}